local http = game:GetService("HttpService")
local function set_wrap(mdl, json)
    local d = http:JSONDecode(json)
    local mp, tx = d.MeshParts or {}, d.Textures or {}

    for _, p in ipairs(mp) do
        for _, o in ipairs(mdl:GetDescendants()) do
            if o:IsA("MeshPart") and o.MeshId == p.MeshId then
                o.Color = Color3.new(unpack(p.Color))
                local m = p.Material:match("Enum.Material.(.+)")
                if m and Enum.Material[m] then o.Material = Enum.Material[m] end
                o.MaterialVariant = p.MaterialVariant or ""
                o.Transparency = p.Transparency or 0
                o.Reflectance = p.Reflectance or 0
                o.TextureID = p.TextureID or ""
            end
        end
    end

    for _, o in ipairs(mdl:GetDescendants()) do
        if o:IsA("Texture") then o:Destroy() end
    end

    for _, t in ipairs(tx) do
        for _, o in ipairs(mdl:GetDescendants()) do
            if o:IsA("MeshPart") and o.MeshId == t.ParentMeshId then
                local nt = Instance.new("Texture")
                nt.Name = t.Name
                nt.Texture = t.Texture
                nt.Color3 = Color3.new(unpack(t.Color3))
                nt.OffsetStudsU, nt.OffsetStudsV = t.OffsetStudsU, t.OffsetStudsV
                nt.StudsPerTileU, nt.StudsPerTileV = t.StudsPerTileU, t.StudsPerTileV
                nt.Transparency, nt.ZIndex = t.Transparency, t.ZIndex
                if t.Face and Enum.NormalId[t.Face] then nt.Face = Enum.NormalId[t.Face] end
                nt.Parent = o
            end
        end
    end
end

