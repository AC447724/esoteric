local function update_skin(w, s)
    local f = fighter.LocalFighter
    if f and f.EquippedItem and f.EquippedItem.Name == w then
        local v = f.EquippedItem.ViewModel
        if v and item_lib.ViewModels[s] then
            v.Name, v.Info = s, item_lib.ViewModels[s]
            if v.Animator then
                v.Animator:StopAllAnimations()
                v.Animator:LoadAnimations()
                v.Animator:PlayIdleAnimation()
            end
        end
    end
end

local function update_wrap(w, n)
    local vms = workspace:FindFirstChild("ViewModels")
    local fp = vms and vms:FindFirstChild("FirstPerson")
    if not fp then return end
    
    for _, m in ipairs(fp:GetChildren()) do
        if m.Name:find(w) then
            local k = w:gsub(" ", "")
            local d = wrap_data[k .. "WrapData"]
            if d and d[k] and d[k][n] then
                set_wrap(m, d[k][n])
            end
        end
    end
end

