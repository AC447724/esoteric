local function drag_gui(name, pos, size, text, color)
    local sg = Instance.new('ScreenGui')
    sg.Name, sg.ResetOnSpawn, sg.IgnoreGuiInset = name, false, true
    pcall(function() sg.Parent = game:GetService('CoreGui') end)
    if not sg.Parent then sg.Parent = lp.PlayerGui end

    local f = Instance.new('Frame', sg)
    f.Name, f.Size, f.Position = 'Frame', size, pos
    f.BackgroundColor3, f.BackgroundTransparency = Color3.fromRGB(12, 12, 12), 0.15
    f.BorderSizePixel, f.Active = 0, true

    Instance.new('UICorner', f).CornerRadius = UDim.new(0, 5)
    local s = Instance.new('UIStroke', f)
    s.Color, s.Thickness = Color3.fromRGB(110, 45, 210), 1

    local l = Instance.new('TextLabel', f)
    l.Name, l.Size, l.Position = 'Label', UDim2.new(1, -8, 1, 0), UDim2.new(0, 6, 0, 0)
    l.BackgroundTransparency, l.TextColor3 = 1, color or Color3.fromRGB(200, 150, 255)
    l.Font, l.TextSize, l.TextXAlignment = Enum.Font.Code, 13, Enum.TextXAlignment.Left
    l.Text, l.RichText = text or '', true

    local drag, d_inp, d_start, s_pos
    f.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            drag, d_start, s_pos = true, i.Position, f.Position
            i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then drag = false end end)
        end
    end)
    f.InputChanged:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then d_inp = i end end)
    uis.InputChanged:Connect(function(i)
        if i == d_inp and drag then
            local del = i.Position - d_start
            f.Position = UDim2.new(s_pos.X.Scale, s_pos.X.Offset + del.X, s_pos.Y.Scale, s_pos.Y.Offset + del.Y)
        end
    end)
    return sg, f, l
end

