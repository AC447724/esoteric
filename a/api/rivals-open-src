local function draw_hat(head_pos, h_val, col, ls)
    local hp, vis = cam:WorldToViewportPoint(head_pos)
    if not vis then return false end
    
    local c_val = h_val / 3.5
    local h_h, h_r, t_o = c_val * cfg.ChinaHatHeight, c_val * cfg.ChinaHatRadius, h_val * 0.18
    local cnt = Vector2.new(hp.X, hp.Y - t_o)
    local top = Vector2.new(cnt.X, cnt.Y - h_h)
    local pts, seg, idx = {}, 24, 1
    
    for i=0, seg-1 do
        local a = (2 * math.pi / seg) * i - 1.57
        table.insert(pts, Vector2.new(cnt.X + math.cos(a) * h_r, cnt.Y + math.sin(a) * h_r * 0.3))
    end
    
    for i=1, seg do
        local l = ls[idx]; l.From, l.To, l.Color, l.Thickness, l.Visible = top, pts[i], col, cfg.ChinaHatThickness, true
        idx = idx + 1
    end
    for i=1, seg do
        local n_i = (i % seg) + 1
        local l = ls[idx]; l.From, l.To, l.Color, l.Thickness, l.Visible = pts[i], pts[n_i], col, cfg.ChinaHatThickness, true
        idx = idx + 1
    end
    for i=1, seg, 4 do
        local opp = ((i + math.floor(seg / 2) - 1) % seg) + 1
        local l = ls[idx]; l.From, l.To, l.Color, l.Thickness, l.Visible = top, pts[opp], col, cfg.ChinaHatThickness/2, true
        idx = idx + 1
    end
    for i=idx, #ls do ls[i].Visible = false end
    return true
end

local function watch_hp(p)
    local function c(char)
        local hum = char:WaitForChild('Humanoid', 10)
        if not hum then return end
        local last = hum.Health
        hum.HealthChanged:Connect(function(hp)
            if hp < last and last > 0 then play_hit() end
            last = hp
        end)
    end
    p.CharacterAdded:Connect(c)
    if p.Character then c(p.Character) end
end
