local function get_pt(c, s)
    if s == 'Random' then
        local p = {'Head', 'UpperTorso', 'LowerTorso', 'LeftUpperArm', 'RightUpperArm', 'LeftLowerLeg', 'RightLowerLeg'}
        return c:FindFirstChild(p[math.random(1, #p)])
    end
    return c:FindFirstChild(s) or c:FindFirstChild('Head')
end

local function visible(p)
    if not p or not lp.Character then return false end
    local par = RaycastParams.new()
    par.FilterType, par.FilterDescendantsInstances, par.IgnoreWater = Enum.RaycastFilterType.Exclude, {lp.Character, cam}, true
    local o, d = cam.CFrame.Position, (p.Position - cam.CFrame.Position)
    local r = workspace:Raycast(o, d, par)
    return r == nil or r.Instance:IsDescendantOf(p.Parent)
end

local function closest()
    if not cfg.SilentAim then return end
    local t, s_dist, m_loc = nil, cfg.Fov, uis:GetMouseLocation()
    for _, v in pairs(ply:GetPlayers()) do
        if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local p = get_pt(v.Character, cfg.SilentAimPart)
            if not p or (cfg.SilentAimWallCheck and not visible(p)) then continue end
            local pos, vis = cam:WorldToViewportPoint(p.Position)
            if vis then
                local d = (Vector2.new(pos.X, pos.Y) - m_loc).Magnitude
                if d < s_dist then s_dist, t = d, p end
            end
        end
    end
    return t
end

