f_ctrl.LocalFighter.GetMouseLocation = function(...)
    local src = debug.info(3, "s")
    if src and src:find("Gun") and cfg.SilentAim then
        local t = closest()
        if t and math.random(1, 100) <= cfg.HitChance then
            local sp, os = cam:WorldToScreenPoint(t.Position)
            if os then return Vector2.new(sp.X, sp.Y) end
        end
    end
    return _old_ml(...)
end

u_mod.Raycast = newcclosure(function(self, o, tp, md, p1, p2, p3)
    if cfg.SilentAim then
        local t = closest()
        if t and math.random(1, 100) <= cfg.HitChance then tp = t.Position end
    end
    return _old_rc(self, o, tp, md, p1, p2, p3)
end)

local function mobile_gui()
    local sg = Instance.new('ScreenGui')
    sg.Name, sg.ResetOnSpawn = 'EsoMobile', false
    pcall(function() sg.Parent = game:GetService('CoreGui') end)
    if not sg.Parent then sg.Parent = lp.PlayerGui end

    local b = Instance.new('TextButton', sg)
    b.Size, b.Position = UDim2.new(0, 45, 0, 45), UDim2.new(1, -60, 0.5, -22)
    b.BackgroundColor3, b.BorderColor3, b.BorderSizePixel = Color3.fromRGB(15, 15, 15), Color3.fromRGB(100, 40, 200), 2
    b.TextColor3, b.Text, b.Font, b.TextSize = Color3.new(1, 1, 1), 'eso', Enum.Font.Code, 14
    Instance.new('UICorner', b).CornerRadius = UDim.new(1, 0)

    local drag, d_inp, d_start, s_pos
    b.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            drag, d_start, s_pos = true, i.Position, b.Position
            i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then drag = false end end)
        end
    end)
    b.InputChanged:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then d_inp = i end end)
    uis.InputChanged:Connect(function(i)
        if i == d_inp and drag then
            local del = i.Position - d_start
            b.Position = UDim2.new(s_pos.X.Scale, s_pos.X.Offset + del.X, s_pos.Y.Scale, s_pos.Y.Offset + del.Y)
        end
    end)
    b.MouseButton1Click:Connect(function()
        pcall(function()
            if type(lib.Toggle) == 'function' then lib:Toggle() elseif type(lib.ToggleUI) == 'function' then lib:ToggleUI() else lib.Enabled = not lib.Enabled end
        end)
    end)
end
