local rot = 0
rs.RenderStepped:Connect(function(dt)
    local m_loc = uis:GetMouseLocation()
    
    if cfg.CamFOVEnabled then cam.FieldOfView = cfg.CamFOV end
    if cfg.ThirdPerson then
        lp.CameraMode, lp.CameraMaxZoomDistance, lp.CameraMinZoomDistance = Enum.CameraMode.Classic, cfg.ThirdPersonDist, cfg.ThirdPersonDist
    else
        lp.CameraMaxZoomDistance, lp.CameraMinZoomDistance = 128, 0.5
    end

    if cfg.PerfOverlay then
        local fps = math.floor(1 / math.max(dt, 0.001))
        local ping = math.floor(pcall(function() return game:GetService("Stats").Network.ServerStatsItem['Data Ping']:GetValue() end) and game:GetService("Stats").Network.ServerStatsItem['Data Ping']:GetValue() or 0)
        perf_l.Text = string.format('<b>FPS:</b> %d  <b>Ping:</b> %dms', fps, ping)
        if cfg.RainbowVisuals then perf_l.TextColor3 = Color3.fromHSV((tick() * cfg.RainbowSpeed) % 1, 1, 1) end
    end

    if cfg.Fullbright then
        local l = game:GetService("Lighting")
        l.Brightness, l.ClockTime, l.FogEnd, l.GlobalShadows = 2, 14, 1e5, false
        l.OutdoorAmbient = Color3.fromRGB(128, 128, 128)
    end

    local c = lp.Character
    if c and c:FindFirstChild('Head') then
        local head = c.Head
        if cfg.ChinaHat then
            if not _h_ls then
                _h_ls = {}
                for i=1, 60 do _h_ls[i] = Drawing.new('Line') end
            end
            local col = cfg.ChinaHatRainbow and Color3.fromHSV((tick() * cfg.RainbowSpeed) % 1, 1, 1) or cfg.ChinaHatColor
            local h_val = math.clamp(500 / (cam.CFrame.Position - head.Position).Magnitude, 10, 100)
            draw_hat(head.Position, h_val, col, _h_ls)
        elseif _h_ls then for _, l in pairs(_h_ls) do l.Visible = false end end
    end

    local a_key = lib.Options and lib.Options.AimBotKey
    if cfg.Aimbot and a_key and a_key:GetState() then
        local t, s_dist = nil, cfg.Fov
        for _, v in pairs(ply:GetPlayers()) do
            if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                local p = get_pt(v.Character, cfg.AimbotPart)
                if p and (not cfg.AimbotWallCheck or visible(p)) then
                    local pos, vis = cam:WorldToViewportPoint(p.Position)
                    if vis then
                        local d = (Vector2.new(pos.X, pos.Y) - m_loc).Magnitude
                        if d < s_dist then s_dist, t = d, p end
                    end
                end
            end
        end
        if t then
            local pos = t.Position
            if cfg.Prediction and t.AssemblyLinearVelocity.Magnitude > 1 then
                pos = pos + (t.AssemblyLinearVelocity * cfg.PredictionAmount)
            end
            if (cam.CFrame.Position - pos).Magnitude > 0.1 then
                cam.CFrame = cam.CFrame:Lerp(CFrame.new(cam.CFrame.Position, pos), math.clamp(cfg.AimSmooth * (dt * 60), 0, 1))
            end
        end
    end
    
    if c and c:FindFirstChild('HumanoidRootPart') and c:FindFirstChild('Humanoid') then
        local hrp, hum = c.HumanoidRootPart, c.Humanoid
        
        if cfg.Fly then
            local v = Vector3.new()
            if uis:IsKeyDown(Enum.KeyCode.W) then v = v + cam.CFrame.LookVector end
            if uis:IsKeyDown(Enum.KeyCode.S) then v = v - cam.CFrame.LookVector end
            if uis:IsKeyDown(Enum.KeyCode.A) then v = v - cam.CFrame.RightVector end
            if uis:IsKeyDown(Enum.KeyCode.D) then v = v + cam.CFrame.RightVector end
            if uis:IsKeyDown(Enum.KeyCode.Space) then v = v + Vector3.new(0, 1, 0) end
            if uis:IsKeyDown(Enum.KeyCode.LeftControl) then v = v - Vector3.new(0, 1, 0) end
            hrp.Velocity = v.Magnitude > 0 and (v.Unit * cfg.FlySpeed) or Vector3.new()
            hum.PlatformStand = true
        else hum.PlatformStand = false end
        
        if cfg.SpeedHack and hum.MoveDirection.Magnitude > 0 then
            hrp.Velocity = Vector3.new(hum.MoveDirection.X * (16 * cfg.SpeedHackMultiplier), hrp.Velocity.Y, hum.MoveDirection.Z * (16 * cfg.SpeedHackMultiplier))
        end
        
        if cfg.InfJump and uis:IsKeyDown(Enum.KeyCode.Space) then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
        
        if cfg.SpinBot and not cfg.Orbit then hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(cfg.SpinSpeed), 0) end
        
        if cfg.Orbit then
            local ot, b_val = nil, math.huge
            if cfg.OrbitTargetMode == 'Highest Health' then b_val = -1 end
            
            for _, v in pairs(ply:GetPlayers()) do
                if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") and v.Character:FindFirstChild("Humanoid") then
                    local p, h = v.Character.HumanoidRootPart, v.Character.Humanoid
                    if cfg.OrbitTargetMode == 'Closest to Mouse' then
                        local pos, vis = cam:WorldToViewportPoint(p.Position)
                        if vis then
                            local d = (Vector2.new(pos.X, pos.Y) - m_loc).Magnitude
                            if d < b_val and d < cfg.Fov then b_val, ot = d, p end
                        end
                    elseif cfg.OrbitTargetMode == 'Closest Distance' then
                        local d = (p.Position - hrp.Position).Magnitude
                        if d < b_val then b_val, ot = d, p end
                    elseif cfg.OrbitTargetMode == 'Lowest Health' then
                        if h.Health > 0 and h.Health < b_val then b_val, ot = h.Health, p end
                    elseif cfg.OrbitTargetMode == 'Highest Health' then
                        if h.Health > 0 and h.Health > b_val then b_val, ot = h.Health, p end
                    end
                end
            end
            
            if ot then
                local r, h = cfg.OrbitRadius, cfg.OrbitHeight
                if cfg.OrbitOscillate then r = r * (1 + math.sin(tick() * 3) * 0.3) end
                
                local off = Vector3.new()
                local mode = cfg.OrbitPosMode
                if mode == 'Circle' then
                    local a = tick() * cfg.OrbitSpeed
                    off = Vector3.new(math.cos(a) * r, h, math.sin(a) * r)
                elseif mode == 'Spiral' then
                    local a = tick() * cfg.OrbitSpeed
                    off = Vector3.new(math.cos(a) * r, h + math.sin(tick() * cfg.OrbitSpeed * 0.5) * (r * 0.8), math.sin(a) * r)
                elseif mode == 'Relative-Behind' then off = (ot.CFrame.LookVector * -r) + Vector3.new(0, h, 0)
                elseif mode == 'Relative-Front' then off = (ot.CFrame.LookVector * r) + Vector3.new(0, h, 0)
                elseif mode == 'Behind' then off = Vector3.new(0, h, r)
                elseif mode == 'Front' then off = Vector3.new(0, h, -r)
                elseif mode == 'Right' then off = Vector3.new(r, h, 0)
                elseif mode == 'Left' then off = Vector3.new(-r, h, 0)
                elseif mode == 'Top' then off = Vector3.new(0, r + h, 0)
                elseif mode == 'Bottom' then off = Vector3.new(0, -r + h, 0)
                end
                hrp.CFrame = hrp.CFrame:Lerp(CFrame.new(ot.Position + off, ot.Position), math.clamp(0.2 * (dt * 60), 0, 1))
            elseif cfg.SpinBot then hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(cfg.SpinSpeed), 0) end
        end
    end
    
    fov_c.Position, fov_c.Thickness = m_loc, cfg.FovThickness
    if cfg.FovPulse then fov_c.Transparency = 0.2 + ((math.sin(tick() * cfg.FovPulseSpeed) + 1) / 2 * 0.8) else fov_c.Transparency = 1 end
    fov_c.Radius = cfg.Fov * (cfg.FovBreathing and (1 + (math.sin(tick() * cfg.FovBreathingSpeed) * (cfg.FovBreathingScale - 1))) or 1)
    
    if cfg.Crosshair then
        c1.Visible, c2.Visible = true, true
        c1.Thickness, c2.Thickness = cfg.CrosshairThickness, cfg.CrosshairThickness
        
        rot = cfg.CrosshairSpin and (rot + cfg.CrosshairSpinSpeed * dt) or (cfg.CrosshairType == 'Plus' and 0 or 45)
        local r1, r2 = math.rad(rot), math.rad(rot + 90)
        local s = cfg.CrosshairSize
        local clr = cfg.RainbowVisuals and Color3.fromHSV((tick() * cfg.RainbowSpeed) % 1, 1, 1) or cfg.CrosshairColor
        c1.Color, c2.Color = clr, clr
        
        c1.From, c1.To = m_loc - Vector2.new(math.cos(r1), math.sin(r1)) * s, m_loc + Vector2.new(math.cos(r1), math.sin(r1)) * s
        c2.From, c2.To = m_loc - Vector2.new(math.cos(r2), math.sin(r2)) * s, m_loc + Vector2.new(math.cos(r2), math.sin(r2)) * s
    else c1.Visible, c2.Visible = false, false end
end)


