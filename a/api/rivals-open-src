local function sec_init()
    local ws_f, jp_f = 16, 50
    local blk_rem = {"Analytics", "Report", "Batch", "Log", "Miscellaneous"}

    local old_idx; old_idx = hookmetamethod(game, "__index", newcclosure(function(s, k)
        if not checkcaller() and s == lp then
            if k == "WalkSpeed" then return ws_f end
            if k == "JumpPower" then return jp_f end
        end
        return old_idx(s, k)
    end))

    local old_nc; old_nc = hookmetamethod(game, "__namecall", newcclosure(function(s, ...)
        local m = getnamecallmethod()
        if not checkcaller() then
            if m == "FireServer" or m == "InvokeServer" then
                local rn = tostring(s)
                for _, b in ipairs(blk_rem) do if rn:find(b) then return nil end end
            elseif (m == "Kick" or m == "kick") and s == lp then
                return nil
            end
        end
        return old_nc(s, ...)
    end))

    local old_sm; old_sm = hookfunction(getrenv().setmetatable, newcclosure(function(t, mt)
        if not checkcaller() and mt and typeof(mt) == "table" and rawget(mt, "__mode") == "kv" then
            if debug.traceback():find("MiscellaneousController") then return old_sm({1, 2, 3}, {}) end
        end
        return old_sm(t, mt)
    end))
end

