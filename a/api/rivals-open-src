local function new_esp(p)
    local ds = {
        Box = Drawing.new('Square'), Lines = {}, Name = Drawing.new('Text'), Dist = Drawing.new('Text'), Tool = Drawing.new('Text'),
        HeadDot = Drawing.new('Circle'), Arrow = Drawing.new('Triangle'), Tracer = Drawing.new('Line'), Skeleton = {},
        HBg = Drawing.new('Line'), HBar = Drawing.new('Line'), CHat = {}
    }
    for i=1, 24 do table.insert(ds.Lines, Drawing.new('Line')) end
    for i=1, 14 do table.insert(ds.Skeleton, Drawing.new('Line')) end
    for i=1, 60 do table.insert(ds.CHat, Drawing.new('Line')) end
    
    local h = Instance.new('Highlight')
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    local h_p = nil
    
    local function hide()
        ds.Box.Visible, ds.Name.Visible, ds.Dist.Visible, ds.Tool.Visible = false, false, false, false
        ds.Arrow.Visible, ds.Tracer.Visible, ds.HeadDot.Visible, ds.HBar.Visible, ds.HBg.Visible = false, false, false, false, false
        for _, l in pairs(ds.Lines) do l.Visible = false end
        for _, l in pairs(ds.Skeleton) do l.Visible = false end
        for _, l in pairs(ds.CHat) do l.Visible = false end
        if h_p then pcall(function() h.Parent = nil end); h_p = nil end
    end

    rs.RenderStepped:Connect(function()
        local char = p.Character
        local hrp = char and char:FindFirstChild('HumanoidRootPart')
        local hum = char and char:FindFirstChildOfClass('Humanoid')
        
        if (p == lp and not cfg.SelfEsp) or not char or not hrp or not hum or hum.Health <= 0 then return hide() end
        local head = char:FindFirstChild('Head')
        if not head then return hide() end
        
        local hrp_p, vis = cam:WorldToViewportPoint(hrp.Position)
        if not vis then return hide() end
        
        local rb = cfg.RainbowVisuals and Color3.fromHSV((tick() * cfg.RainbowSpeed) % 1, 1, 1) or nil
        if cfg.ChinaHatOthers then
            local h_col = cfg.ChinaHatRainbow and Color3.fromHSV((tick() * cfg.RainbowSpeed) % 1, 1, 1) or cfg.ChinaHatColor
            local h_v = math.abs(cam:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0)).Y - cam:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0)).Y)
            draw_hat(head.Position, h_v, h_col, ds.CHat)
        else for _, l in pairs(ds.CHat) do l.Visible = false end end

        if not cfg.EspEnabled then
            ds.Box.Visible, ds.Name.Visible, ds.Dist.Visible, ds.Tool.Visible = false, false, false, false
            ds.Arrow.Visible, ds.Tracer.Visible, ds.HeadDot.Visible, ds.HBar.Visible, ds.HBg.Visible = false, false, false, false, false
            for _, l in pairs(ds.Lines) do l.Visible = false end
            for _, l in pairs(ds.Skeleton) do l.Visible = false end
            if h_p then pcall(function() h.Parent = nil end); h_p = nil end
            return
        end
        if cfg.Chams then 
            if h_p ~= char then pcall(function() h.Parent = char end); h_p = char end
            h.FillColor, h.OutlineColor = rb or cfg.ChamsFill, rb or cfg.ChamsOutline
        elseif h_p then pcall(function() h.Parent = nil end); h_p = nil end
        
        local head = char:FindFirstChild('Head')
        if not head then return hide() end
        
        local cframe, size = char:GetBoundingBox()
        local cp, vis = cam:WorldToViewportPoint(cframe.Position)
        if not vis then return hide() end
        
        local top = cam:WorldToViewportPoint(cframe.Position + Vector3.new(0, size.Y/2, 0))
        local bot = cam:WorldToViewportPoint(cframe.Position - Vector3.new(0, size.Y/2, 0))
        local h_val, off = math.abs(top.Y - bot.Y), cfg.BoxOffset
        local w_val = (h_val * 0.6) * cfg.BoxWidthMult + off
        h_val = h_val + off
        local cx = cp.X
        local x, y = cx - w_val/2, top.Y - (off/2)
        local col, thk = rb or cfg.BoxColor, cfg.BoxThickness
        
        for _, l in pairs(ds.Lines) do l.Visible = false end
        ds.Box.Visible = false
        
        if cfg.BoxType == '2D' then
            ds.Box.Size, ds.Box.Position, ds.Box.Color = Vector2.new(w_val, h_val), Vector2.new(x, y), col
            ds.Box.Thickness, ds.Box.Visible, ds.Box.Filled = thk, true, false
        elseif cfg.BoxType == '2D Corner' then
            local cl, l = w_val/4, ds.Lines
            l[1].From, l[1].To = Vector2.new(x, y), Vector2.new(x + cl, y)
            l[2].From, l[2].To = Vector2.new(x, y), Vector2.new(x, y + cl)
            l[3].From, l[3].To = Vector2.new(x + w_val, y), Vector2.new(x + w_val - cl, y)
            l[4].From, l[4].To = Vector2.new(x + w_val, y), Vector2.new(x + w_val, y + cl)
            l[5].From, l[5].To = Vector2.new(x, y + h_val), Vector2.new(x + cl, y + h_val)
            l[6].From, l[6].To = Vector2.new(x, y + h_val), Vector2.new(x, y + h_val - cl)
            l[7].From, l[7].To = Vector2.new(x + w_val, y + h_val), Vector2.new(x + w_val - cl, y + h_val)
            l[8].From, l[8].To = Vector2.new(x + w_val, y + h_val), Vector2.new(x + w_val, y + h_val - cl)
            for i=1, 8 do l[i].Visible, l[i].Color, l[i].Thickness = true, col, thk end
        elseif cfg.BoxType:find('3D') then
            local s3 = size + Vector3.new(off/5, off/5, off/5)
            local bcf = cframe
            local c3 = {
                (bcf*CFrame.new( s3.X/2, s3.Y/2, s3.Z/2)).Position, (bcf*CFrame.new(-s3.X/2, s3.Y/2, s3.Z/2)).Position,
                (bcf*CFrame.new(-s3.X/2, s3.Y/2, -s3.Z/2)).Position, (bcf*CFrame.new( s3.X/2, s3.Y/2, -s3.Z/2)).Position,
                (bcf*CFrame.new( s3.X/2,-s3.Y/2, s3.Z/2)).Position, (bcf*CFrame.new(-s3.X/2,-s3.Y/2, s3.Z/2)).Position,
                (bcf*CFrame.new(-s3.X/2,-s3.Y/2, -s3.Z/2)).Position, (bcf*CFrame.new( s3.X/2,-s3.Y/2, -s3.Z/2)).Position,
            }
            local pts = {}
            for _, cr in pairs(c3) do local ps = cam:WorldToViewportPoint(cr) table.insert(pts, Vector2.new(ps.X, ps.Y)) end
            local e = {{1,2},{2,3},{3,4},{4,1},{5,6},{6,7},{7,8},{8,5},{1,5},{2,6},{3,7},{4,8}}
            if cfg.BoxType == '3D' then
                for i, v in ipairs(e) do ds.Lines[i].From, ds.Lines[i].To, ds.Lines[i].Color, ds.Lines[i].Thickness, ds.Lines[i].Visible = pts[v[1]], pts[v[2]], col, thk, true end
            else
                local idx = 1
                for _, v in ipairs(e) do
                    local pA, pB = pts[v[1]], pts[v[2]]
                    local dn = (pB - pA).Unit * ((pB - pA).Magnitude / 4)
                    ds.Lines[idx].From, ds.Lines[idx].To = pA, pA+dn
                    ds.Lines[idx+1].From, ds.Lines[idx+1].To = pB, pB-dn
                    ds.Lines[idx].Visible, ds.Lines[idx+1].Visible = true, true
                    ds.Lines[idx].Color, ds.Lines[idx+1].Color = col, col
                    ds.Lines[idx].Thickness, ds.Lines[idx+1].Thickness = thk, thk
                    idx = idx + 2
                end
            end
        end
        
        if cfg.HealthBar and hum then
            local hp_pct, bx = math.clamp(hum.Health / (hum.MaxHealth > 0 and hum.MaxHealth or 100), 0, 1), x - 6
            ds.HBg.From, ds.HBg.To, ds.HBg.Color, ds.HBg.Thickness, ds.HBg.Visible = Vector2.new(bx, y), Vector2.new(bx, y+h_val), Color3.new(0.2,0.2,0.2), 3, true
            ds.HBar.From, ds.HBar.To, ds.HBar.Color, ds.HBar.Thickness, ds.HBar.Visible = Vector2.new(bx, y+h_val), Vector2.new(bx, y+h_val-(h_val*hp_pct)), Color3.new(1-hp_pct, hp_pct, 0), 1, true
        else ds.HBg.Visible, ds.HBar.Visible = false, false end
        
        if cfg.Skeletons then
            local sc = rb or cfg.SkeletonColor
            for i, b in ipairs(skel_bones) do
                local l = ds.Skeleton[i]
                local f, t = char:FindFirstChild(b[1]), char:FindFirstChild(b[2])
                if f and t then
                    local fp, fv = cam:WorldToViewportPoint(f.Position)
                    local tp, tv = cam:WorldToViewportPoint(t.Position)
                    if fv and tv then
                        l.From, l.To, l.Color, l.Thickness, l.Visible = Vector2.new(fp.X, fp.Y), Vector2.new(tp.X, tp.Y), sc, cfg.EspSkeletonThickness, true
                    else l.Visible = false end
                else l.Visible = false end
            end
        else for _, l in pairs(ds.Skeleton) do l.Visible = false end end
        
        if cfg.HeadDot then
            local hp, v = cam:WorldToViewportPoint(head.Position)
            ds.HeadDot.Position, ds.HeadDot.Radius, ds.HeadDot.Color, ds.HeadDot.Filled, ds.HeadDot.Visible = Vector2.new(hp.X, hp.Y), cfg.HeadDotSize, rb or cfg.HeadDotColor, true, true
        else ds.HeadDot.Visible = false end
        
        if cfg.Tracers then
            ds.Tracer.From, ds.Tracer.To = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y), Vector2.new(x + w_val/2, y + h_val)
            ds.Tracer.Color, ds.Tracer.Thickness, ds.Tracer.Visible = rb or cfg.TracerColor, 1, true
        else ds.Tracer.Visible = false end
        
        if cfg.ViewArrow then
            local sC = cam:WorldToViewportPoint(head.Position)
            local ah = cam:WorldToViewportPoint(head.Position + head.CFrame.LookVector * 4)
            local d = (Vector2.new(ah.X, ah.Y) - Vector2.new(sC.X, sC.Y)).Unit
            local perp = Vector2.new(-d.Y, d.X)
            local b = Vector2.new(x + w_val/2, y - 10)
            ds.Arrow.PointA, ds.Arrow.PointB, ds.Arrow.PointC = b + d * 15, b + perp * 4, b - perp * 4
            ds.Arrow.Color, ds.Arrow.Filled, ds.Arrow.Visible = rb or cfg.ViewArrowColor, true, true
        else ds.Arrow.Visible = false end

        local stk = {Top = {}, Bottom = {}, Left = {}, Right = {}}
        if cfg.ShowName then table.insert(stk[cfg.NamePos], {p.Name, rb or cfg.NameColor, ds.Name}) end
        if cfg.ShowDistance then table.insert(stk[cfg.DistPos], {math.round((hrp.Position - cam.CFrame.Position).Magnitude) .. 'm', rb or cfg.DistanceColor, ds.Dist}) end
        if cfg.ShowItem then table.insert(stk[cfg.ItemPos], {get_item(char), rb or cfg.ItemColor, ds.Tool}) end
        
        ds.Name.Visible, ds.Dist.Visible, ds.Tool.Visible = false, false, false
        local ty, by, ly, ry = 0, 0, 0, 0
        local f_sz = cfg.EspFontSize
        for _, i in ipairs(stk.Top) do i[3].Text, i[3].Color, i[3].Size, i[3].Center, i[3].Position, i[3].Visible = i[1], i[2], f_sz, true, Vector2.new(x+w_val/2, y-15-ty), true; ty = ty + f_sz end
        for _, i in ipairs(stk.Bottom) do i[3].Text, i[3].Color, i[3].Size, i[3].Center, i[3].Position, i[3].Visible = i[1], i[2], f_sz, true, Vector2.new(x+w_val/2, y+h_val+2+by), true; by = by + f_sz end
        for _, i in ipairs(stk.Left) do i[3].Text, i[3].Color, i[3].Size, i[3].Center, i[3].Position, i[3].Visible = i[1], i[2], f_sz, false, Vector2.new(x-5-i[3].TextBounds.X, y+ly), true; ly = ly + f_sz end
        for _, i in ipairs(stk.Right) do i[3].Text, i[3].Color, i[3].Size, i[3].Center, i[3].Position, i[3].Visible = i[1], i[2], f_sz, false, Vector2.new(x+w_val+5, y+ry), true; ry = ry + f_sz end
    end)
end

